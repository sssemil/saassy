# Copy to .env and fill in real values. `docker compose up` reads from here.

# --- Postgres (user-gateway's own database lives here) ---
POSTGRES_USER=saassy
POSTGRES_PASSWORD=please_change_me

# --- user-gateway ---
# Generate with: openssl rand -base64 32
JWT_SECRET=please_change_me_to_a_random_32_byte_secret

# Resend (https://resend.com) for magic-link emails. Placeholder works for smoke tests
# that don't actually send; replace with a real key to receive login links.
RESEND_API_KEY=placeholder
EMAIL_FROM=noreply@saassy.xyz

# Public origin users reach the app from. Must include scheme.
# Dev: http://localhost (or http://localhost:8080 if Caddy publishes 8080)
# Prod: https://saassy.xyz
APP_ORIGIN=http://localhost

# Comma-separated list of emails auto-promoted to admin on magic-link login.
ADMIN_EMAILS=

# Impersonation access-token TTL. Admins are logged out of admin when they
# impersonate; the session lives this long before requiring a fresh admin login.
IMPERSONATION_TTL_MINUTES=60

RUST_LOG=info

# --- Caddy ---
# Dev: leave SITE_ADDRESS unset (defaults to plain HTTP on :80).
# Prod: set SITE_ADDRESS to your domain (e.g. saassy.xyz) and Caddy
# auto-provisions TLS via Let's Encrypt. You'll need ports 80 and 443 open.
# SITE_ADDRESS=saassy.xyz

# Host ports Caddy binds to. Defaults are 80/443; override if those are taken.
CADDY_HTTP_PORT=80
CADDY_HTTPS_PORT=443

  "query": "\n                SELECT id, email, language, created_at, updated_at, last_login_at, is_admin, is_frozen\n                FROM users\n                WHERE LOWER(email) LIKE $1\n                ORDER BY created_at DESC\n                LIMIT $2 OFFSET $3\n            ",

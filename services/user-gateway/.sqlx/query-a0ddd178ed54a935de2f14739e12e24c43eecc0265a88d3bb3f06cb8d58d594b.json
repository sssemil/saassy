  "query": "\n                INSERT INTO users (id, email, language)\n                VALUES ($1, $2, $3)\n                ON CONFLICT (email) DO UPDATE\n                SET language = COALESCE($3, users.language)\n                RETURNING id, email, language, created_at, updated_at, last_login_at, is_admin, is_frozen\n            ",

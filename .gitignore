# Environment & editor
.env
.env.test
.idea
*.log

# Rust
services/user-gateway/target/
target/

# Node / Next.js (all services)
services/*/node_modules/
services/*/.next/
services/*/.turbo/
services/*/.vercel/
services/*/npm-debug.log*
services/*/yarn-error.log*
services/*/package-lock.json
services/*/tsconfig.tsbuildinfo
services/*/next-env.d.ts

# Build-time mirror of the canonical SKILL.md; the Pages workflow copies
# it here before uploading the artifact. Never commit it.
docs/SKILL.md

# SQLx offline cache: keep committed, but ignore any generated db dumps
*.sql.dump

# Secrets — generated locally via infra/generate-secrets.sh
infra/secrets/*
!infra/secrets/.gitkeep

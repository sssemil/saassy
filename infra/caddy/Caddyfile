# SITE_ADDRESS defaults to plain HTTP on :80 for local dev.
# In prod, set SITE_ADDRESS=saassy.xyz (no scheme) in .env and Caddy auto-
# provisions TLS via Let's Encrypt using the HTTP-01 challenge on port 80.
{$SITE_ADDRESS:http://:80} {
	encode gzip

	# user-gateway — the Rust API (auth, users, admin, audit)
	handle /api/* {
		reverse_proxy user-gateway:3001
	}

	# admin-ui — reusable admin panel
	handle /admin* {
		reverse_proxy admin-ui:3100
	}

	# user-ingress — reusable end-user auth + profile UI
	handle /login {
		reverse_proxy user-ingress:3200
	}
	handle /magic {
		reverse_proxy user-ingress:3200
	}
	handle /profile* {
		reverse_proxy user-ingress:3200
	}
	handle /callback/* {
		reverse_proxy user-ingress:3200
	}

	# project-web — the project-specific frontend, catches everything else
	handle {
		reverse_proxy project-web:3000
	}
}

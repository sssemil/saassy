# SITE_ADDRESS defaults to plain HTTP on :80 for local dev.
# In prod, set SITE_ADDRESS=saassy.xyz (no scheme) in .env and Caddy auto-
# provisions TLS via Let's Encrypt using the HTTP-01 challenge on port 80.
{$SITE_ADDRESS:http://:80} {
	encode gzip

	# Baseline security headers. HSTS is only emitted when Caddy is serving
	# HTTPS (i.e. when SITE_ADDRESS is a real domain) — sending it on plain
	# HTTP would be a no-op at best and a footgun at worst.
	header {
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "geolocation=(), microphone=(), camera=()"
		# Strip the Server header so it doesn't advertise Caddy version.
		-Server
	}
	@https {
		protocol https
	}
	header @https Strict-Transport-Security "max-age=31536000; includeSubDomains"

	# user-gateway — the Rust API (auth, users, admin, audit)
	handle /api/* {
		reverse_proxy user-gateway:3001
	}

	# admin-ui — reusable admin panel
	handle /admin* {
		reverse_proxy admin-ui:3100
	}

	# user-ingress — reusable end-user auth + profile UI
	handle /login {
		reverse_proxy user-ingress:3200
	}
	handle /magic {
		reverse_proxy user-ingress:3200
	}
	handle /profile* {
		reverse_proxy user-ingress:3200
	}
	handle /callback/* {
		reverse_proxy user-ingress:3200
	}

	# project-web — the project-specific frontend, catches everything else
	handle {
		reverse_proxy project-web:3000
	}
}
